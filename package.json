{
  "name": "chiqo-ai",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "chiqo.ai — local creator intelligence workspace by Macroview Studio.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "npm --prefix server install && npm --prefix client install",
    "build": "npm --prefix client run build",
    "start": "node scripts/launch.js",
    "dist": "node scripts/make-dist.js",
    "dev": "concurrently --kill-others-on-fail --names server,client --prefix-colors blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --prefix server run dev",
    "dev:client": "npm --prefix client run dev",
    "electron:prep": "npm --prefix server ci --omit=dev --no-audit --no-fund && npm run build",
    "electron:dev": "npm run electron:prep && node scripts/run-electron.cjs",
    "electron:build": "npm run electron:prep && electron-builder",
    "electron:build:win": "npm run electron:prep && electron-builder --win",
    "electron:build:mac": "npm run electron:prep && electron-builder --mac"
  },
  "build": {
    "appId": "ai.chiqo.app",
    "productName": "chiqo.ai",
    "copyright": "Copyright © 2026 Macroview Studio",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!.env",
          "!users.json",
          "!.session-secret"
        ]
      },
      {
        "from": "client/dist",
        "to": "client/dist"
      },
      "SWH_Instagram_Agent_Prompt.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "chiqo.ai"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  }
}
