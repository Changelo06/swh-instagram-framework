{
  "name": "chiqo-ai",
  "version": "1.4.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "description": "chiqo.ai — local creator intelligence workspace by Macroview Studio.",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "setup": "npm --prefix client install",
    "build": "npm --prefix client run build",
    "postinstall": "node scripts/fetch-electron-prebuild.cjs",
    "dev": "npm --prefix client run dev",
    "test:vault": "node scripts/test-vault.cjs",
    "electron:prep": "npm run build",
    "electron:dev": "npm run electron:prep && node scripts/run-electron.cjs",
    "electron:build": "npm run electron:prep && electron-builder",
    "electron:build:win": "npm run electron:prep && electron-builder --win",
    "electron:build:win:dir": "npm run electron:prep && electron-builder --win --dir",
    "electron:build:mac": "npm run electron:prep && electron-builder --mac"
  },
  "build": {
    "appId": "ai.chiqo.app",
    "productName": "chiqo.ai",
    "copyright": "Copyright © 2026 Macroview Studio",
    "directories": {
      "output": "dist-electron",
      "buildResources": "build"
    },
    "files": [
      "electron/**/*",
      "package.json",
      "node_modules/@anthropic-ai/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/hash-wasm/**/*",
      "node_modules/csv-parse/**/*"
    ],
    "asarUnpack": [
      "**/*.node",
      "node_modules/better-sqlite3/build/**/*"
    ],
    "extraResources": [
      {
        "from": "client/dist",
        "to": "client/dist"
      },
      {
        "from": "SWH_Instagram_Agent_Prompt.md",
        "to": "SWH_Instagram_Agent_Prompt.md"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "chiqo.ai"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    }
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "better-sqlite3": "^12.10.0",
    "csv-parse": "^5.5.6",
    "hash-wasm": "^4.12.0"
  }
}
