# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic — used for the framework analysis (Claude).
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Groq — used for Whisper transcription of reel audio (optional).
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Parallel transcriptions. Lower if you hit Groq rate limits, raise for speed.
TRANSCRIBE_CONCURRENCY=4

# Apify — used to scrape Instagram profiles + reels.
# Get a token: https://console.apify.com/account#/integrations
APIFY_TOKEN=

PORT=3001
