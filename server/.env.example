# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic — used for the framework analysis (Claude).
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
CLAUDE_MODEL=claude-sonnet-4-6

# Groq (free) — used for Whisper transcription of reel audio.
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=gsk_REPLACE_ME
GROQ_WHISPER_MODEL=whisper-large-v3-turbo

# Parallel transcriptions. Lower if you hit Groq rate limits, raise for speed.
TRANSCRIBE_CONCURRENCY=4

PORT=3001
